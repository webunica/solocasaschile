# ═══════════════════════════════════════════════
# Variables de Entorno — solocasaschile.com
# ═══════════════════════════════════════════════

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=tu_project_id_aqui
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_WRITE_TOKEN=tu_token_de_escritura_aqui

# NextAuth
NEXTAUTH_SECRET=una_clave_secreta_larga_y_aleatoria_de_32chars
NEXTAUTH_URL=http://localhost:3000

# ═══════════════════════════════════════════════
# Resend (Envío de Emails) — https://resend.com
# 1. Crea una cuenta en resend.com (gratis hasta 3000 emails/mes)
# 2. Verifica tu dominio solocasaschile.com
# 3. Copia la API Key y pégala aquí
# ═══════════════════════════════════════════════
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email del Admin (recibe CC de todos los leads)
ADMIN_EMAIL=admin@solocasaschile.com

# Email remitente (debe ser de tu dominio verificado en Resend)
FROM_EMAIL=no-reply@solocasaschile.com
